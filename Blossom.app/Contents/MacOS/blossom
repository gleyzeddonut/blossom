#!/bin/bash
# Blossom launcher: fully self-contained. Code lives in Contents/Resources;
# the Python environment and settings live in ~/Library/Application Support/Blossom.
LOG=/tmp/blossom-launch.log
RES="$(cd "$(dirname "$0")/../Resources" && pwd)"
APPDIR="$HOME/Library/Application Support/Blossom"
# One-time migration from the app's previous name.
OLDDIR="$HOME/Library/Application Support/Orchid"
if [ -d "$OLDDIR" ] && [ ! -d "$APPDIR" ]; then
    mv "$OLDDIR" "$APPDIR"
fi
VENV="$APPDIR/venv"
LOCAL_PY="$APPDIR/python/bin/python3"

# Standalone CPython download, used when the machine has no usable Python
# (newest macOS no longer ships one with the Command Line Tools).
PBS_TAG="20260718"
PBS_VER="cpython-3.12.13"
case "$(uname -m)" in
    arm64) PBS_ARCH="aarch64" ;;
    *)     PBS_ARCH="x86_64" ;;
esac
PY_URL="https://github.com/astral-sh/python-build-standalone/releases/download/${PBS_TAG}/${PBS_VER}+${PBS_TAG}-${PBS_ARCH}-apple-darwin-install_only.tar.gz"

{
    echo "=== launch $(date) ==="
    echo "resources: $RES"
    echo "venv: $VENV"
} >>"$LOG" 2>&1

BLOCKED=0

# probe <python>: succeeds if it runs at all; notes TCC denials.
probe() {
    local out
    out="$("$1" -c "pass" 2>&1)" && return 0
    echo "probe $1 failed: $out" >>"$LOG"
    case "$out" in *"Operation not permitted"*) BLOCKED=1 ;; esac
    return 1
}

alert() { osascript -e "display alert \"Blossom\" message \"$1\""; }

download_python() {
    osascript -e 'display notification "First launch: downloading Python runtime…" with title "Blossom"' 2>/dev/null
    echo "downloading $PY_URL" >>"$LOG"
    mkdir -p "$APPDIR"
    curl -fsSL --retry 2 -o "$APPDIR/python.tar.gz" "$PY_URL" >>"$LOG" 2>&1 || return 1
    rm -rf "$APPDIR/python"
    tar -xzf "$APPDIR/python.tar.gz" -C "$APPDIR" >>"$LOG" 2>&1 || return 1
    rm -f "$APPDIR/python.tar.gz"
    [ -x "$LOCAL_PY" ]
}

if ! "$VENV/bin/python" -c "import mido, rtmidi, AppKit" >>"$LOG" 2>&1; then
    echo "venv unusable; (re)building" >>"$LOG"
    PY=""
    for p in "$LOCAL_PY" /usr/bin/python3 "$(command -v python3 2>/dev/null)"; do
        if [ -n "$p" ] && [ -x "$p" ] && probe "$p"; then
            PY="$p"
            break
        fi
    done
    if [ -z "$PY" ] && [ "$BLOCKED" != 1 ]; then
        # No Python on this machine — fetch our own standalone runtime.
        if download_python; then
            PY="$LOCAL_PY"
        fi
    fi
    if [ -z "$PY" ]; then
        if [ "$BLOCKED" = 1 ]; then
            alert "macOS is blocking Blossom from reading files it needs. Details: $LOG"
        else
            alert "Blossom could not find or download a Python runtime. Check your internet connection and try again. Details: $LOG"
        fi
        exit 1
    fi
    rm -rf "$VENV"
    mkdir -p "$APPDIR"
    "$PY" -m venv "$VENV" >>"$LOG" 2>&1
    "$VENV/bin/python" -m pip install -r "$RES/requirements.txt" >>"$LOG" 2>&1
    if ! "$VENV/bin/python" -c "import mido, rtmidi, AppKit" >>"$LOG" 2>&1; then
        alert "Blossom could not set up its Python environment. Details: $LOG"
        exit 1
    fi
fi

# Run from the downloaded update if it is strictly newer than the bundle.
APP_CODE="$RES"
OVERRIDE="$APPDIR/app"
if [ -f "$OVERRIDE/VERSION" ] && [ -f "$OVERRIDE/gui.py" ]; then
    if "$VENV/bin/python" -c '
import sys
def v(path):
    try:
        return tuple(int(x) for x in open(path + "/VERSION").read().strip().split("."))
    except Exception:
        return (0,)
sys.exit(0 if v(sys.argv[1]) > v(sys.argv[2]) else 1)' "$OVERRIDE" "$RES"; then
        APP_CODE="$OVERRIDE"
    fi
fi
echo "launching gui.py from $APP_CODE" >>"$LOG"
cd "$APP_CODE"
exec "$VENV/bin/python" "$APP_CODE/gui.py" 2>>"$LOG"
